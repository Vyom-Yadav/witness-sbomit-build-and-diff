# SBOMit Accuracy Analyzer - Environment Configuration
# Copy this to .env and fill in your values

# LLM Provider (OpenRouter)
SBOMIT_OPENROUTER_API_KEY=your-openrouter-api-key-here
SBOMIT_OPENROUTER_MODEL=openai/gpt-4o-mini
SBOMIT_CLASSIFIER_MODEL=openai/gpt-4o-mini

# Build Environment
SBOMIT_BUILD_BASE_IMAGE=sbomit-analyzer:base

# Discovery Agent Limits
SBOMIT_MAX_TOOL_CALLS=4
SBOMIT_MIN_CONFIDENCE=0.5

# Storage
SBOMIT_DB_PATH=data/analysis.db

# Temporal
SBOMIT_TEMPORAL_ADDRESS=localhost:7233
SBOMIT_TEMPORAL_TASK_QUEUE=sbomit-analyzer
